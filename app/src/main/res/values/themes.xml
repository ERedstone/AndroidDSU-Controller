<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.AndroidDSU" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/buttonx</item>
        <item name="colorPrimaryVariant">@color/background</item>
        <item name="colorOnPrimary">#021B07</item>
        <!-- Secondary brand color. -->
        <item name="android:textColor">@color/buttonx</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/background</item>

        <!-- Customize your theme here. -->
        <!-- 开屏背景色 -->
        <item name="android:windowSplashScreenBackground">@color/background</item>

        <!-- 开屏中心图标 -->
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>

        <!-- 动画持续时间（毫秒） -->
        <item name="android:windowSplashScreenAnimationDuration">50</item>
        <item name="actionOverflowMenuStyle">@style/OverflowMenu</item>
    </style>
    <style name="MyEditText" parent="Theme.AppCompat.Light">
        <item name="colorControlNormal">@color/buttonx</item>
        <item name="colorControlActivated">@color/buttonx</item>
    </style>
    <style name="scstyle" parent="Theme.AppCompat.Light">
        <!--开启时的颜色-->
        <item name="colorControlActivated">@color/spical</item>
        <!--关闭时的颜色-->
        <item name="colorSwitchThumbNormal">@color/buttonx</item>
        <!--关闭时的轨迹颜色-->
        <item name="android:colorForeground">@color/buttonx</item>
    </style>
    <style name="OverflowMenu" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="overlapAnchor">false</item>
        <item name="android:dropDownVerticalOffset">4dp</item>
        <item name="android:layout_marginRight">4dp</item>
        <item name="android:popupBackground">@drawable/background</item>

    </style>



</resources>